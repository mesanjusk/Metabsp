# WhatsApp Cloud BSP (Metabsp)
VITE_API_LOCAL=http://localhost:5000
VITE_API_SERVER=https://your-backend.onrender.com
VITE_SOCKET_URL=https://your-backend.onrender.com

# Bulk-invite (Event Management) — must point at the /api/bulk prefix
VITE_API_URL=https://your-backend.onrender.com/api/bulk

# Cloudinary (used by Bulk-invite uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
