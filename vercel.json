{
  "version": 2,
  "framework": "vite",
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "build": {
    "env": {
      "VITE_API_SERVER": "https://bulk-invite.onrender.com",
      "VITE_API_URL": "https://bulk-invite.onrender.com/api/bulk",
      "VITE_SOCKET_URL": "https://bulk-invite.onrender.com"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
