PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mis
ACCESS_TOKEN_SECRET=replace_with_jwt_secret

# Meta / WhatsApp Cloud
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v18.0
META_API_TOKEN=your_permanent_system_user_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token
VERIFY_TOKEN=your_random_webhook_verify_token
WHATSAPP_ENFORCE_WEBHOOK_SIGNATURE=true
WHATSAPP_TOKEN_ENCRYPTION_KEY=base64_encoded_32_byte_key

# Only needed if this app receives messages forwarded from another project's
# webhook-destinations fan-out instead of owning the Meta webhook directly.
# Value must match the secret shown once when the destination was created
# (or last regenerated) on the sending project.
WHATSAPP_FORWARD_SECRET=paste_the_destination_secret_here




