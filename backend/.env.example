PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/mis
FRONTEND_URL=http://localhost:5173

# Required for the broadcast send queue (src/queues/) and, later, the
# distributed rate limiter and BullMQ-backed background jobs.
REDIS_URL=redis://127.0.0.1:6379

# ── Auth (shared by every login path — Cloud and Bulk both use this) ────────
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
# ACCESS_TOKEN_SECRET is a legacy alias for JWT_SECRET, read only if
# JWT_SECRET is unset. Set JWT_SECRET going forward.
# ACCESS_TOKEN_SECRET=replace_with_jwt_secret

# BOOTSTRAP_USERNAME/PASSWORD: optional env-configured super-admin login that
# upserts (and keeps in sync with) a real DB user on first use.
# BOOTSTRAP_USERNAME=
# BOOTSTRAP_NAME=
# BOOTSTRAP_PASSWORD=

# SUPER_ADMIN_USERNAME/PASSWORD: set both to seed a super admin at boot.
# There is no default password — leaving these unset just skips seeding.
# SUPER_ADMIN_USERNAME=
# SUPER_ADMIN_NAME=
# SUPER_ADMIN_MOBILE=
# SUPER_ADMIN_PASSWORD=

# ── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# WHATSAPP_API_VERSION is the canonical name; META_API_VERSION is a legacy
# alias read as a fallback (see backend/src/config/graphApi.js).
WHATSAPP_API_VERSION=v20.0
META_API_TOKEN=your_permanent_system_user_access_token
# Facebook Login for Business configuration ID for the WhatsApp Embedded
# Signup flow (Meta App Dashboard -> WhatsApp -> Embedded Signup). Required
# for the "Connect" button's real Embedded Signup path; without it the UI
# tells the user to use "Connect manually" instead.
META_EMBEDDED_SIGNUP_CONFIG_ID=your_embedded_signup_config_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token
WHATSAPP_ENFORCE_WEBHOOK_SIGNATURE=true
WHATSAPP_TOKEN_ENCRYPTION_KEY=base64_encoded_32_byte_key
WHATSAPP_TEMPLATE_LANGUAGE=en_US

# Shared/legacy env-config WhatsApp number, used only for platform-sent OTPs
# (not per-user messaging — see src/services/otpService.js).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Cloudinary (media uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Billing (UPI Autopay via Cashfree) ───────────────────────────────────────
# See src/services/paymentGatewayService.js — verify field names/signature
# scheme against Cashfree's current docs before enabling in production.
CASHFREE_ENV=sandbox
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_API_VERSION=2023-08-01

# ── AI chatbot auto-reply (optional) ─────────────────────────────────────────
# Required only for AutoReply rules with ruleType: 'ai_assistant'.
# See src/services/aiChatbotService.js.
ANTHROPIC_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
